<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="mcp_audit_log_view_tree" model="ir.ui.view">
        <field name="name">mcp.audit.log.list</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <list string="MCP Audit Log" create="false" edit="false"
                  decoration-danger="response_status == 'denied'"
                  decoration-warning="response_status == 'error'"
                  decoration-success="response_status == 'success'">
                <field name="timestamp"/>
                <field name="user_id"/>
                <field name="model_name"/>
                <field name="operation"/>
                <field name="method_name" optional="show"/>
                <field name="record_count"/>
                <field name="response_status"
                       decoration-danger="response_status == 'denied'"
                       decoration-warning="response_status == 'error'"
                       decoration-success="response_status == 'success'"
                       widget="badge"/>
                <field name="duration_ms" optional="show"/>
                <field name="ip_address" optional="hide"/>
                <field name="endpoint_type" optional="show"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="mcp_audit_log_view_form" model="ir.ui.view">
        <field name="name">mcp.audit.log.form</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <form string="MCP Audit Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group string="Request">
                            <field name="timestamp"/>
                            <field name="user_id"/>
                            <field name="endpoint_type"/>
                            <field name="ip_address"/>
                            <field name="user_agent"/>
                        </group>
                        <group string="Operation">
                            <field name="model_name"/>
                            <field name="operation"/>
                            <field name="method_name"/>
                            <field name="record_ids"/>
                            <field name="record_count"/>
                        </group>
                    </group>
                    <group>
                        <group string="Response">
                            <field name="response_status"
                                   decoration-danger="response_status == 'denied'"
                                   decoration-warning="response_status == 'error'"
                                   decoration-success="response_status == 'success'"
                                   widget="badge"/>
                            <field name="duration_ms"/>
                        </group>
                    </group>
                    <group string="Request Data" invisible="not request_data">
                        <field name="request_data" nolabel="1"/>
                    </group>
                    <group string="Error Details" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="mcp_audit_log_view_search" model="ir.ui.view">
        <field name="name">mcp.audit.log.search</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <search string="MCP Audit Log">
                <field name="user_id"/>
                <field name="model_name"/>
                <field name="operation"/>
                <field name="ip_address"/>
                <separator/>
                <filter string="Success" name="success" domain="[('response_status', '=', 'success')]"/>
                <filter string="Errors" name="errors" domain="[('response_status', '=', 'error')]"/>
                <filter string="Denied" name="denied" domain="[('response_status', '=', 'denied')]"/>
                <separator/>
                <filter string="REST" name="rest" domain="[('endpoint_type', '=', 'rest')]"/>
                <filter string="XML-RPC" name="xmlrpc" domain="[('endpoint_type', '=', 'xmlrpc')]"/>
                <separator/>
                <filter string="Today" name="today"
                        domain="[('timestamp', '>=', (context_today()).strftime('%%Y-%%m-%%d'))]"/>
                <filter string="Last 7 Days" name="last_week"
                        domain="[('timestamp', '>=', (context_today() - datetime.timedelta(days=7)).strftime('%%Y-%%m-%%d'))]"/>
                <group>
                    <filter string="User" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Model" name="group_model" context="{'group_by': 'model_name'}"/>
                    <filter string="Operation" name="group_operation" context="{'group_by': 'operation'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'response_status'}"/>
                    <filter string="Endpoint" name="group_endpoint" context="{'group_by': 'endpoint_type'}"/>
                    <filter string="Day" name="group_day" context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Graph View -->
    <record id="mcp_audit_log_view_graph" model="ir.ui.view">
        <field name="name">mcp.audit.log.graph</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <graph string="MCP Audit Log" type="bar">
                <field name="timestamp" interval="day"/>
                <field name="operation" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="mcp_audit_log_view_pivot" model="ir.ui.view">
        <field name="name">mcp.audit.log.pivot</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <pivot string="MCP Audit Log">
                <field name="timestamp" interval="day" type="row"/>
                <field name="operation" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Action -->
    <record id="action_mcp_audit_log" model="ir.actions.act_window">
        <field name="name">MCP Audit Logs</field>
        <field name="res_model">mcp.audit.log</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No MCP audit logs yet
            </p>
            <p>
                Audit logs will appear here when AI assistants
                access Odoo data via the MCP API.
            </p>
        </field>
    </record>

</odoo>
