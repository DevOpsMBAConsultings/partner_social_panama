<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_social_panama" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.social.panama</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='website']" position="after">
                <field name="social_facebook" widget="url" placeholder="facebook.com/usuario..."/>
                <field name="social_instagram" widget="url" placeholder="instagram.com/usuario..."/>
                <field name="social_linkedin" widget="url" placeholder="linkedin.com/in/usuario..."/>
            </xpath>
        </field>
    </record>
</odoo>
