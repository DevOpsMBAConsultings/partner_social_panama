<odoo>
    <record id="module_category_st_car_rental" model="ir.module.category">
        <field name="name">Car Rental</field>
        <field name="description">Category for Car Rental Management groups</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_rental_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_st_car_rental"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('fleet.fleet_group_user'))]"/>
    </record>

    <record id="group_rental_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_st_car_rental"/>
        <field name="implied_ids" eval="[(4, ref('group_rental_user')), (4, ref('fleet.fleet_group_manager'))]"/>
    </record>
</odoo>
