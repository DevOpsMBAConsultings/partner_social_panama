<odoo>
    <!-- Kanban View for Dashboard -->
    <record id="rental_vehicle_view_kanban_dashboard" model="ir.ui.view">
        <field name="name">fleet.vehicle.kanban.rental.dashboard</field>
        <field name="model">fleet.vehicle</field>
        <field name="arch" type="xml">
            <kanban default_group_by="rental_status" class="o_kanban_mobile" sample="1">
                <field name="rental_status" />
                <field name="is_rentable" />
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title">
                                    <field name="display_name" />
                                </strong>
                            </div>
                        </div>
                        <div class="o_kanban_record_body">
                            <field name="tag_ids" widget="many2many_tags" />
                            <div>
                                <field name="license_plate" />
                            </div>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <field name="activity_ids" widget="kanban_activity" />
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="rental_rate_id" />
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Calendar View for Rental Bookings (on Sale Order) -->
    <record id="rental_order_view_calendar" model="ir.ui.view">
        <field name="name">sale.order.calendar.rental</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <calendar string="Rentals" date_start="pickup_date" date_stop="return_date"
                color="vehicle_id" quick_create="0">
                <field name="partner_id" avatar_field="avatar_128" />
                <field name="vehicle_id" />
                <field name="state" filters="1" />
            </calendar>
        </field>
    </record>

    <!-- Action for Dashboard -->
    <record id="action_rental_dashboard" model="ir.actions.act_window">
        <field name="name">Rental Dashboard</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_rentable', '=', True)]</field>
        <field name="context">{'default_is_rentable': True, 'search_default_groupby_status': 1}</field>
        <field name="view_id" ref="rental_vehicle_view_kanban_dashboard" />
    </record>

    <!-- Action for Calendar -->
    <record id="action_rental_calendar" model="ir.actions.act_window">
        <field name="name">Rental Calendar</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="domain">[('is_rental', '=', True)]</field>
        <field name="context">{'default_is_rental': True}</field>
    </record>
</odoo>