<odoo>
    <record id="rental_location_view_tree" model="ir.ui.view">
        <field name="name">rental.location.view.tree</field>
        <field name="model">rental.location</field>
        <field name="arch" type="xml">
            <list string="Rental Locations">
                <field name="complete_name" />
                <field name="type" />
                <field name="city" />
                <field name="country_id" />
                <field name="active" widget="boolean_toggle" />
            </list>
        </field>
    </record>

    <record id="rental_location_view_form" model="ir.ui.view">
        <field name="name">rental.location.view.form</field>
        <field name="model">rental.location</field>
        <field name="arch" type="xml">
            <form string="Rental Location">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                        invisible="active" />
                    <field name="active" invisible="1" />
                    <div class="oe_title">
                        <label for="name" string="Location Name" />
                        <h1>
                            <field name="name" placeholder="e.g. Miami Airport..." />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="parent_id" />
                            <field name="type" />
                            <field name="company_id" groups="base.group_multi_company" />
                        </group>
                        <group string="Address Details" invisible="type not in ('city', 'branch')">
                            <label for="street" string="Address" />
                            <div class="o_address_format">
                                <field name="street" placeholder="Street..."
                                    class="o_address_street" />
                                <field name="street2" placeholder="Street 2..."
                                    class="o_address_street" />
                                <field name="city" placeholder="City" class="o_address_city" />
                                <field name="state_id" class="o_address_state" placeholder="State"
                                    options="{'no_open': True, 'no_quick_create': True}" />
                                <field name="zip" placeholder="ZIP" class="o_address_zip" />
                                <field name="country_id" placeholder="Country"
                                    class="o_address_country"
                                    options="{'no_open': True, 'no_create': True}" />
                            </div>
                            <field name="latitude" />
                            <field name="longitude" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="rental_location_action" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">rental.location</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new rental location
            </p>
            <p>
                Manage your service areas, branches, and parking spots.
            </p>
        </field>
    </record>
</odoo>