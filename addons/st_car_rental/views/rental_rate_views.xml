<odoo>
    <record id="rental_rate_view_tree" model="ir.ui.view">
        <field name="name">rental.rate.view.tree</field>
        <field name="model">rental.rate</field>
        <field name="arch" type="xml">
            <list string="Rental Rates">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="daily_rate" />
                <field name="weekly_rate" />
                <field name="monthly_rate" />
                <field name="currency_id" column_invisible="True" />
            </list>
        </field>
    </record>

    <record id="rental_rate_view_form" model="ir.ui.view">
        <field name="name">rental.rate.view.form</field>
        <field name="model">rental.rate</field>
        <field name="arch" type="xml">
            <form string="Rental Rate">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Economy Daily" />
                        </h1>
                    </div>
                    <group>
                        <group name="pricing" string="Pricing">
                            <field name="daily_rate" />
                            <field name="hourly_rate" />
                            <field name="currency_id" invisible="1" />
                        </group>
                        <group string="Extended Rates">
                            <field name="weekly_rate" />
                            <field name="biweekly_rate" />
                            <field name="monthly_rate" />
                        </group>
                        <group name="settings" string="Settings">
                            <field name="sequence" />
                            <field name="active" widget="boolean_toggle" />
                            <field name="company_id" groups="base.group_multi_company" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Terms &amp; Notes" name="notes">
                            <field name="notes" placeholder="Detailed terms for this rate..." />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="rental_rate_action" model="ir.actions.act_window">
        <field name="name">Rental Rates</field>
        <field name="res_model">rental.rate</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first rental rate!
            </p>
        </field>
    </record>
</odoo>