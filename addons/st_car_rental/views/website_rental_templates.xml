<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template for the Catalog List of Cars -->
    <template id="rental_cars_list_template" name="Rent a Car Catalog">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_title pt32 pb32" data-vcss="001" data-snippet="s_title">
                    <div class="container s_allow_columns">
                        <div class="row align-items-center">
                            <div class="col-lg-12">
                                <h1 class="text-center">
                                    <b>Our Rental Fleet</b>
                                </h1>
                                <p class="lead text-center">Find the perfect vehicle for your next
                                    journey.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <div class="container my-4">
                    <!-- Search & Availability Strip -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="card shadow-sm border-0 rounded-3 bg-light">
                                <div class="card-body p-3">
                                    <form action="/rental/cars" method="get"
                                        class="row gx-2 gy-2 align-items-end">
                                        <div class="col-md-4">
                                            <label for="branch_id" class="form-label fw-bold mb-1">Select
                                                Branch</label>
                                            <select class="form-select" id="branch_id"
                                                name="branch_id">
                                                <option value="">All Branches</option>
                                                <t t-foreach="locations" t-as="loc">
                                                    <option t-att-value="loc.id"
                                                        t-att-selected="loc.id == search_branch_id">
                                                        <t t-esc="loc.display_name" />
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label for="pickup_date" class="form-label fw-bold mb-1">
                                                Pick-up</label>
                                            <input type="datetime-local" class="form-control"
                                                name="pickup_date" t-att-value="search_pickup" />
                                        </div>
                                        <div class="col-md-3">
                                            <label for="return_date" class="form-label fw-bold mb-1">
                                                Return</label>
                                            <input type="datetime-local" class="form-control"
                                                name="return_date" t-att-value="search_return" />
                                        </div>
                                        <div class="col-md-2">
                                            <button type="submit"
                                                class="btn btn-primary w-100 fw-bold">Search Cars</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Vehicle Loop -->
                        <t t-foreach="vehicles" t-as="vehicle">
                            <div class="col-md-4 mb-4">
                                <div class="card h-100 shadow-sm border-0 rounded-3">
                                    <t t-if="vehicle.image_128">
                                        <img class="card-img-top rounded-top-3"
                                            t-attf-src="data:image/png;base64,{{vehicle.image_128}}"
                                            alt="Vehicle Image"
                                            style="height: 200px; object-fit: cover;" />
                                    </t>
                                    <t t-else="">
                                        <div
                                            class="card-img-top rounded-top-3 bg-light d-flex align-items-center justify-content-center text-muted"
                                            style="height: 200px;">
                                            <i class="fa fa-car fa-4x"></i>
                                        </div>
                                    </t>
                                    <div class="card-body d-flex flex-column">
                                        <h4 class="card-title fw-bold">
                                            <t t-esc="vehicle.name" />
                                        </h4>
                                        <p class="card-text text-muted mb-2">
                                            <i class="fa fa-map-marker me-2"></i>
                                            <t t-if="vehicle.current_location_id">
                                                <t t-esc="vehicle.current_location_id.name" />
                                            </t>
                                            <t t-else="">Various Locations</t>
                                        </p>
                                        <div class="mt-auto">
                                            <t t-if="vehicle.rental_rate_id">
                                                <h5 class="text-primary mb-3"> Starting from <t
                                                        t-esc="vehicle.rental_rate_id.daily_rate"
                                                        t-options="{'widget': 'monetary', 'display_currency': vehicle.company_id.currency_id}" />
                                                    / day </h5>
                                            </t>
                                            <a
                                                t-attf-href="/rental/car/{{vehicle.id}}?pickup_date={{search_pickup}}&amp;return_date={{search_return}}&amp;pickup_location_id={{search_branch_id}}"
                                                class="btn btn-primary w-100 fw-bold">Book Now</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                        <t t-if="not vehicles">
                            <div class="col-12 text-center text-muted my-5">
                                <h3>No vehicles are currently available.</h3>
                                <p>Please check back later.</p>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Template for the Vehicle Details & Booking Form -->
    <template id="rental_car_detail_template" name="Rent a Car Details">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <div class="container my-5">

                    <t t-if="error == 'missing_fields'">
                        <div class="alert alert-danger" role="alert">
                            <strong>Error!</strong> Please fill in all the required dates and
                            locations to proceed with booking. </div>
                    </t>

                    <div class="row">
                        <!-- Vehicle Image & Specs -->
                        <div class="col-lg-7 mb-4">
                            <div class="card shadow-sm border-0 rounded-3">
                                <t t-if="vehicle.image_128">
                                    <img class="card-img-top rounded-top-3"
                                        t-attf-src="data:image/png;base64,{{vehicle.image_128}}"
                                        alt="Vehicle Image"
                                        style="max-height: 400px; object-fit: contain; background: #f8f9fa;" />
                                </t>
                                <div class="card-body">
                                    <h2 class="fw-bold mb-3">
                                        <t t-esc="vehicle.name" />
                                    </h2>

                                    <h4 class="text-muted mb-4">Vehicle Specifications</h4>
                                    <div class="row text-center mb-4">
                                        <div class="col-4 border-end">
                                            <i class="fa fa-users fa-2x mb-2 text-primary"></i>
                                            <p class="mb-0 fw-bold"><t t-esc="vehicle.seats" />
                                                Seats</p>
                                        </div>
                                        <div class="col-4 border-end">
                                            <i class="fa fa-cogs fa-2x mb-2 text-primary"></i>
                                            <p class="mb-0 fw-bold">
                                                <t t-esc="vehicle.transmission"
                                                    style="text-transform: capitalize;" />
                                            </p>
                                        </div>
                                        <div class="col-4">
                                            <i class="fa fa-tint fa-2x mb-2 text-primary"></i>
                                            <p class="mb-0 fw-bold">
                                                <t t-esc="vehicle.fuel_type"
                                                    style="text-transform: capitalize;" />
                                            </p>
                                        </div>
                                    </div>

                                    <t t-if="vehicle.rental_rate_id">
                                        <h4 class="text-muted mt-4 border-top pt-4">Pricing Guide</h4>
                                        <table class="table table-sm mt-3">
                                            <tbody>
                                                <tr t-if="vehicle.rental_rate_id.hourly_rate > 0">
                                                    <td>Hourly Rate</td>
                                                    <td class="text-end fw-bold">
                                                        <t
                                                            t-esc="vehicle.rental_rate_id.hourly_rate"
                                                            t-options="{'widget': 'monetary', 'display_currency': vehicle.company_id.currency_id}" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Daily Rate</td>
                                                    <td class="text-end fw-bold">
                                                        <t t-esc="vehicle.rental_rate_id.daily_rate"
                                                            t-options="{'widget': 'monetary', 'display_currency': vehicle.company_id.currency_id}" />
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <td>Weekly Rate</td>
                                                    <td class="text-end fw-bold">
                                                        <t
                                                            t-esc="vehicle.rental_rate_id.weekly_rate"
                                                            t-options="{'widget': 'monetary', 'display_currency': vehicle.company_id.currency_id}" />
                                                    </td>
                                                </tr>
                                                <tr t-if="vehicle.rental_rate_id.monthly_rate > 0">
                                                    <td>Monthly Rate</td>
                                                    <td class="text-end fw-bold">
                                                        <t
                                                            t-esc="vehicle.rental_rate_id.monthly_rate"
                                                            t-options="{'widget': 'monetary', 'display_currency': vehicle.company_id.currency_id}" />
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                        <small class="text-muted">*Final price will automatically
                                            adjust to guarantee the lowest cost for your duration.</small>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Booking Form Sidebar -->
                        <div class="col-lg-5">
                            <div class="card shadow border-0 rounded-3 bg-light sticky-top"
                                style="top: 2rem;">
                                <div class="card-body p-4">
                                    <h3 class="fw-bold border-bottom pb-3 mb-4">Book this Vehicle</h3>

                                    <form action="/rental/book" method="post"
                                        enctype="multipart/form-data">
                                        <input type="hidden" name="csrf_token"
                                            t-att-value="request.csrf_token()" />
                                        <input type="hidden" name="vehicle_id"
                                            t-att-value="vehicle.id" />

                                        <!-- Locations -->
                                        <div class="mb-3">
                                            <label for="pickup_location_id"
                                                class="form-label fw-bold">Pick-up Location</label>
                                            <select class="form-select" id="pickup_location_id"
                                                name="pickup_location_id" required="1">
                                                <option value=""
                                                    t-att-disabled="not pickup_location_id"
                                                    t-att-selected="not pickup_location_id">Select a
                                                    branch...</option>
                                                <t t-foreach="locations" t-as="loc">
                                                    <option t-att-value="loc.id"
                                                        t-att-selected="str(loc.id) == str(pickup_location_id)">
                                                        <t t-esc="loc.display_name" />
                                                    </option>
                                                </t>
                                            </select>
                                        </div>

                                        <div class="mb-4">
                                            <label for="return_location_id"
                                                class="form-label fw-bold">Return Location</label>
                                            <select class="form-select" id="return_location_id"
                                                name="return_location_id" required="1">
                                                <option value=""
                                                    t-att-disabled="not pickup_location_id"
                                                    t-att-selected="not pickup_location_id">Select a
                                                    branch...</option>
                                                <t t-foreach="locations" t-as="loc">
                                                    <option t-att-value="loc.id">
                                                        <t t-esc="loc.display_name" />
                                                    </option>
                                                </t>
                                            </select>
                                        </div>

                                        <!-- Dates -->
                                        <div class="mb-3">
                                            <label for="pickup_date" class="form-label fw-bold">Pick-up
                                                Date &amp; Time</label>
                                            <input type="datetime-local" class="form-control"
                                                id="pickup_date" name="pickup_date" required="1"
                                                t-att-value="pickup_date" />
                                        </div>

                                        <div class="mb-4">
                                            <label for="return_date" class="form-label fw-bold">Return
                                                Date &amp; Time</label>
                                            <input type="datetime-local" class="form-control"
                                                id="return_date" name="return_date" required="1"
                                                t-att-value="return_date" />
                                        </div>

                                        <!-- Optional Accessories (Cross-Selling) -->
                                        <t t-if="vehicle.accessory_product_ids">
                                            <div class="mb-4">
                                                <label
                                                    class="form-label fw-bold border-bottom pb-2 mb-3 d-block">Optional
                                                    Extras</label>
                                                <t t-foreach="vehicle.accessory_product_ids"
                                                    t-as="accessory">
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input"
                                                            type="checkbox" name="accessory_ids"
                                                            t-att-value="accessory.id"
                                                            t-att-id="'acc_' + str(accessory.id)" />
                                                        <label
                                                            class="form-check-label d-flex justify-content-between w-100"
                                                            t-att-for="'acc_' + str(accessory.id)">
                                                            <span>
                                                                <t t-esc="accessory.name" />
                                                            </span>
                                                            <strong class="text-primary">+<t
                                                                    t-esc="accessory.list_price"
                                                                    t-options="{'widget': 'monetary', 'display_currency': vehicle.company_id.currency_id}" /></strong>
                                                        </label>
                                                    </div>
                                                </t>
                                            </div>
                                        </t>

                                        <button type="submit"
                                            class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                                            <i class="fa fa-shopping-cart me-2"></i> Confirm Booking </button>
                                        <p class="text-center text-muted small mt-3 mb-0">You won't
                                            be charged yet.</p>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>